# ── Server (Optional) ─────────────────────────────────────────
PORT=3000

# ── App (Optional) ────────────────────────────────────────────
# Username allowed to upload custom emojis
EMOJI_ADMIN=iron

# ── Supabase (Required) ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=service_role_key_here
SUPABASE_MEDIA_BUCKET=curon-media
SUPABASE_DB_BUCKET=curon-db

# ── JWT Secret (Required) ──────────────────────────────────────
JWT_SECRET=generate_a_random_secret_here

# ── Seed Passwords (Required in production, optional in dev) ───
# If not set in development, defaults to '1' and '2'
SEED_PASSWORD_IRON=your_iron_password
SEED_PASSWORD_CUBBY=your_cubby_password

# ── Spotify (Optional) ─────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# ── GIF API (Optional) ─────────────────────────────────────────
KLIPY_API_KEY=

# ── Media Cleanup (Optional) ───────────────────────────────────
# Set to 0 to disable auto-cleanup of unstarred media older than 14 days
MEDIA_CLEANUP_INTERVAL_MS=21600000
